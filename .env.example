# LLM Configuration
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.4-mini
# OPENAI_API_KEY=your-openai-api-key-here
# # Optional: overrides the per-model default reasoning effort for both providers
# # (e.g. low/medium/high). Leave unset to use each model config's hardcoded default.
# LLM_REASONING_EFFORT=low

# Mistral Configuration (if using Mistral)
LLM_PROVIDER=mistral
LLM_MODEL=mistral-medium-latest
MISTRAL_API_KEY=your-mistral-api-key-here
LLM_REASONING_EFFORT=high

# Simulator Configuration
SIMULATOR_GROUP=10

# Logging
LOG_LEVEL=DEBUG
