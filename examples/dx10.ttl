td:hasActionAffordance [
dct:description "Turns off all active components of the machine: It sets the conveyor speed to 0, it restarts the stack light sensor, it closes the filler`s magnetic valve, and it returns the Cartesian robot (and the attached filler) to its home position at the start of the belt." ;
rdf:type onto:StopInEmergencyAction ,
td:ActionAffordance ;
td:hasForm [
rdf:type hctl:Form ;
http:methodName "POST" ;
hctl:forContentType "application/json" ;
hctl:hasOperationType td:invokeAction ;
hctl:hasTarget <https://ci.mines-stetienne.fr/simu/fillingWorkshop/actions/pressEmergencyStop>
] ;
td:isIdempotent "false"^^xsd:boolean ;
td:isSafe "false"^^xsd:boolean ;
td:name "pressEmergencyStop" ;
td:title "Press Emergency Stop"
] ;
td:hasForm [
hctl:forContentType "application/json" ;
hctl:hasOperationType td:readAllProperties ,
td:readMultipleProperties ,
td:writeAllProperties ,
td:writeMultipleProperties ;
hctl:hasTarget <https://ci.mines-stetienne.fr/simu/fillingWorkshop/all/properties>
] ;
td:hasPropertyAffordance [
dct:description "Reads the status of the magnetic valve which controls the product flow of the tank. When the status is true, product (e.g. yogurt) is flowing from the tank to an item (e.g. a container)." ;
rdf:type onto:ValveStatus ,
jsonschema:BooleanSchema ,
td:PropertyAffordance ;
jsonschema:readOnly "true"^^xsd:boolean ;
jsonschema:writeOnly "false"^^xsd:boolean ;
td:hasForm [
rdf:type hctl:Form ;
http:methodName "GET" ;
hctl:forContentType "application/json" ;
hctl:hasOperationType td:readProperty ;
hctl:hasTarget <https://ci.mines-stetienne.fr/simu/fillingWorkshop/properties/magneticValveStatus>
] ;
td:isObservable "false"^^xsd:boolean ;
td:name "magneticValveStatus" ;
td:title "Magnetic Valve Status"
] ,
[
dct:description "Reads the position of the Cartesian motor on the X axis (in meters)." ;
rdf:type onto:XCoordinate ,
jsonschema:NumberSchema ,
td:PropertyAffordance ;
jsonschema:readOnly "true"^^xsd:boolean ;
jsonschema:writeOnly "false"^^xsd:boolean ;
td:hasForm [
rdf:type hctl:Form ;
http:methodName "GET" ;
hctl:forContentType "application/json" ;
hctl:hasOperationType td:readProperty ;
hctl:hasTarget <https://ci.mines-stetienne.fr/simu/fillingWorkshop/properties/positionX>
] ;
td:isObservable "false"^^xsd:boolean ;
td:name "positionX" ;
td:title "Position X"
] ,
[
dct:description "Reads the status of the optical sensor that detects whether an item is positioned at the start of the conveyor belt under the filler." ;
rdf:type onto:OpticalSensorStatus ,
jsonschema:BooleanSchema ,
td:PropertyAffordance ;
ssn:forProperty <https://ci.mines-stetienne.fr/kg/itmfactory/dx10/conveyor/upstream-presence#this> ;
jsonschema:readOnly "true"^^xsd:boolean ;
jsonschema:writeOnly "false"^^xsd:boolean ;
td:hasForm [
rdf:type hctl:Form ;
http:methodName "GET" ;
hctl:forContentType "application/json" ;
hctl:hasOperationType td:readProperty ;
hctl:hasTarget <https://ci.mines-stetienne.fr/simu/fillingWorkshop/properties/opticalSensorStatus>
] ;
td:isObservable "false"^^xsd:boolean ;
td:name "opticalSensorStatus" ;
td:title "Optical Sensor Status"
] ,
